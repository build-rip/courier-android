<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: dataExtractionRules -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="datastore/auth_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/auth_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
